{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECRFull",
      "Effect": "Allow",
      "Action": ["ecr:*"],
      "Resource": "*"
    },
    {
      "Sid": "EKSAccess",
      "Effect": "Allow",
      "Action": [
        "eks:DescribeCluster",
        "eks:ListClusters",
        "eks:UpdateClusterConfig",
        "eks:AccessKubernetesApi"
      ],
      "Resource": "*"
    },
    {
      "Sid": "TerraformState",
      "Effect": "Allow",
      "Action": ["s3:GetObject","s3:PutObject","s3:DeleteObject","s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::kayo-terraform-state",
        "arn:aws:s3:::kayo-terraform-state/*"
      ]
    },
    {
      "Sid": "TerraformLock",
      "Effect": "Allow",
      "Action": ["dynamodb:GetItem","dynamodb:PutItem","dynamodb:DeleteItem"],
      "Resource": "arn:aws:dynamodb:us-east-1:058264278824:table/kayo-terraform-locks"
    },
    {
      "Sid": "TerraformProvision",
      "Effect": "Allow",
      "Action": [
        "ec2:*","vpc:*","rds:*","elasticache:*","kafka:*",
        "iam:CreateRole","iam:DeleteRole","iam:AttachRolePolicy","iam:DetachRolePolicy",
        "iam:CreatePolicy","iam:DeletePolicy","iam:GetRole","iam:GetPolicy",
        "iam:ListRolePolicies","iam:ListAttachedRolePolicies","iam:PassRole",
        "iam:CreateInstanceProfile","iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile","iam:RemoveRoleFromInstanceProfile",
        "iam:CreateOpenIDConnectProvider","iam:DeleteOpenIDConnectProvider",
        "iam:GetOpenIDConnectProvider","iam:TagOpenIDConnectProvider",
        "kms:CreateKey","kms:DescribeKey","kms:CreateAlias","kms:DeleteAlias",
        "kms:EnableKeyRotation","kms:GetKeyPolicy","kms:ListAliases",
        "kms:ScheduleKeyDeletion","kms:TagResource",
        "logs:CreateLogGroup","logs:DeleteLogGroup","logs:DescribeLogGroups",
        "logs:PutRetentionPolicy"
      ],
      "Resource": "*"
    }
  ]
}
